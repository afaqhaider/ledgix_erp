rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper Functions
    function signedIn() {
      return request.auth != null;
    }

    function isMember(companyId) {
      // Cross-service rules to check active membership in Firestore
      return signedIn() &&
             firestore.get(/databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function isLogoImage() {
      return request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Storage path: companies/{companyId}/...
    match /companies/{companyId}/{allPaths=**} {

      // Strict isolation: must be an active member of the company
      allow read: if isMember(companyId);

      // Branding (Logos)
      match /branding/{fileName} {
        allow write: if isMember(companyId) && isLogoImage();
      }

      // General documents (attachments for invoices, etc.)
      match /documents/{fileName} {
        allow write: if isMember(companyId);
      }
    }

    // User profile photos
    match /users/{uid}/profile/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Fallback: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
